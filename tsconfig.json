{
    "compilerOptions": {
        "rootDir": "src",
        "outDir": "dist",
        "target": "es2015",
        "lib": [
            "es2022"
        ],
        "moduleResolution": "nodenext",
        "module": "NodeNext",
        "types": [
            "node"
        ],
        "allowJs": true,
        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,
        "declaration": true,
        "inlineSourceMap": false,
        "listEmittedFiles": false,
        "listFiles": false,
        "noFallthroughCasesInSwitch": true,
        "pretty": true,
        "skipLibCheck": true,
        "strict": true,
        "traceResolution": false,
        "importHelpers": false,
        "strictPropertyInitialization": true,
        "noUnusedLocals": true
    },
    "include": [
        "src/**/*.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}
