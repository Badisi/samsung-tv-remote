{
    "name": "samsung-tv-remote",
    "version": "3.0.7",
    "description": "Remote client for Samsung SmartTV starting from 2016",
    "homepage": "https://github.com/Badisi/samsung-tv-remote",
    "license": "MIT",
    "author": {
        "name": "Badisi"
    },
    "type": "module",
    "main": "./index.cjs",
    "module": "./index.mjs",
    "types": "./index.d.mts",
    "exports": {
        ".": {
            "import": {
                "types": "./index.d.mts",
                "default": "./index.mjs"
            },
            "require": {
                "types": "./index.d.cts",
                "default": "./index.cjs"
            }
        },
        "./package.json": "./package.json"
    },
    "bin": {
        "samsung-tv-remote": "bin/samsung-tv-remote"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Badisi/samsung-tv-remote.git"
    },
    "keywords": [
        "samsung",
        "smarttv",
        "remote"
    ],
    "scripts": {
        "check-updates": "npx @badisi/check-updates -i",
        "start": "tsx ./src/cli.ts --verbose",
        "test:cjs": "LOG_LEVEL=debug tsx ./tests/test.cjs",
        "test:mjs": "LOG_LEVEL=info tsx ./tests/test.mjs",
        "typecheck": "tsc --noEmit",
        "build": "tsc --noEmit && tsdown",
        "release": "npm publish ./dist --access public"
    },
    "dependencies": {
        "wake_on_lan": "^1.0.0",
        "ws": "^8.21.0"
    },
    "devDependencies": {
        "@types/node": "^26.1.1",
        "@types/wake_on_lan": "^0.0.33",
        "@types/ws": "^8.18.1",
        "tsdown": "^0.22.4",
        "tsx": "^4.23.0",
        "typescript": "^6.0.3"
    },
    "optionalDependencies": {
        "bufferutil": "^4.1.0"
    },
    "allowScripts": {
        "bufferutil@4.1.0": true
    }
}
